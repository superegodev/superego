{
  "overrides": [
    {
      "files": ["*.sql"],
      "options": { "parser": "sqlite" }
    },
    {
      "files": "*.astro",
      "options": { "parser": "astro" }
    },
    {
      "files": "*.sh",
      "options": { "parser": "sh" }
    }
  ],
  "plugins": [
    "prettier-plugin-sql-cst",
    "prettier-plugin-astro",
    "prettier-plugin-sh"
  ]
}
