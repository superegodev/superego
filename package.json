{
  "name": "@superego/root",
  "version": "2026.2.2",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/**/*"
  ],
  "scripts": {
    "test": "CI=true yarn workspaces foreach --all --topological-dev --verbose run test",
    "check-types": "yarn workspaces foreach --all --topological-dev --verbose run check-types",
    "check-translations": "yarn workspaces foreach --all --topological-dev --verbose run check-translations",
    "check-linting": "biome lint",
    "fix-linting": "biome lint --write",
    "check-formatting": "biome check --linter-enabled=false && prettier --list-different \"**/*.(md|yml|sql|sh)\"",
    "fix-formatting": "biome check --linter-enabled=false --write && prettier --write \"**/*.(md|yml|sql|sh)\"",
    "build-website": "yarn workspace @superego/website build",
    "deploy-website:production": "yarn workspace @superego/website deploy:production",
    "deploy-website:preview": "yarn workspace @superego/website deploy:preview",
    "build-demo:preview": "yarn workspace @superego/demo-app build:preview",
    "build-demo:production": "yarn workspace @superego/demo-app build:production",
    "deploy-demo:preview": "yarn workspace @superego/demo-app deploy:preview",
    "deploy-demo:production": "yarn workspace @superego/demo-app deploy:production",
    "build-electron": "yarn workspace @superego/electron-app build",
    "deploy-electron": "yarn workspace @superego/electron-app deploy",
    "prepare-release": "node scripts/prepareRelease.ts",
    "playwright": "playwright"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-sql-cst": "^0.18.0",
    "typescript": "^5.9.3",
    "zx": "8.8.5-lite"
  },
  "resolutions": {
    "browserslist": "4.28.1",
    "baseline-browser-mapping": "2.9.19"
  },
  "packageManager": "yarn@4.13.0+sha512.5c20ba010c99815433e5c8453112165e673f1c7948d8d2b267f4b5e52097538658388ebc9f9580656d9b75c5cc996f990f611f99304a2197d4c56d21eea370e7"
}
