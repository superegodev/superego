{
  "name": "@superego/browser-app",
  "version": "2026.3.8",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.tsx"
    },
    "./monaco": {
      "import": "./src/monaco.ts"
    },
    "./vite.config.js": {
      "import": "./vite.config.ts"
    }
  },
  "scripts": {
    "dev": "vite",
    "dev:host": "USE_HTTPS=true vite --host",
    "clear-vite-cache": "rm -rf node_modules/.vite node_modules/.vite-temp",
    "check-types": "tsc --noEmit",
    "test": "vitest --reporter=verbose",
    "check-translations": "node scripts/checkTranslations.ts",
    "translations:extract": "formatjs extract 'src/**/*.ts*' --ignore='**/*.d.ts' --id-interpolation-pattern='[name].[ext]_[sha512:contenthash:base64:6]' --out-file src/translations/en.json",
    "translations:compile": "formatjs compile-folder --ast src/translations/ src/translations/compiled",
    "translations:verify": "formatjs verify --missing-keys --structural-equality --source-locale en 'src/translations/*.json'",
    "translations:extract-and-compile": "yarn translations:extract && yarn translations:compile"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "0.18.0-b1c6bfc",
    "@geoman-io/maplibre-geoman-free": "^0.7.1",
    "@hookform/resolvers": "^5.2.2",
    "@msgpack/msgpack": "^3.1.3",
    "@react-aria/optimize-locales-plugin": "^1.2.0",
    "@standard-schema/spec": "^1.1.0",
    "@superego/backend": "workspace:*",
    "@superego/echarts": "workspace:*",
    "@superego/global-types": "workspace:*",
    "@superego/javascript-sandbox-global-utils": "workspace:*",
    "@superego/schema": "workspace:*",
    "@superego/shared-utils": "workspace:*",
    "@tanstack/react-query": "^5.100.3",
    "@tiptap/extension-code-block-lowlight": "^3.22.4",
    "@tiptap/extension-list": "^3.22.4",
    "@tiptap/extension-subscript": "^3.22.4",
    "@tiptap/extension-superscript": "^3.22.4",
    "@tiptap/extension-text-align": "^3.22.4",
    "@tiptap/extension-text-style": "^3.22.4",
    "@tiptap/extension-typography": "^3.22.4",
    "@tiptap/extensions": "^3.22.4",
    "@tiptap/pm": "^3.22.4",
    "@tiptap/react": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "@vanilla-extract/css": "^1.20.1",
    "@vanilla-extract/vite-plugin": "^5.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "debounce": "^3.0.0",
    "es-toolkit": "^1.46.0",
    "frimousse": "^0.3.0",
    "lowlight": "^3.3.0",
    "luxon": "^3.7.2",
    "maplibre-gl": "^5.24.0",
    "markdown-to-jsx": "9.7.16",
    "monaco-editor": "0.55.1",
    "overtype": "patch:overtype@npm%3A2.3.5#~/.yarn/patches/overtype-npm-2.3.5-4c11984e75.patch",
    "p-map": "^7.0.4",
    "p-timeout": "^7.0.1",
    "react": "^19.2.5",
    "react-aria": "^3.48.0",
    "react-aria-components": "^1.17.0",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.73.1",
    "react-icons": "^5.6.0",
    "react-intl": "^10.1.3",
    "react-stately": "^3.46.0",
    "react-zoom-pan-pinch": "^4.0.3",
    "valibot": "^1.3.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@fast-check/vitest": "^0.4.0",
    "@formatjs/cli": "^6.14.3",
    "@formatjs/unplugin": "^1.1.8",
    "@superego/app-sandbox": "workspace:*",
    "@superego/connectors": "workspace:*",
    "@superego/demo-data-repositories": "workspace:*",
    "@superego/executing-backend": "workspace:*",
    "@superego/monaco-typescript-compiler": "workspace:*",
    "@superego/multi-driver-inference-service": "workspace:*",
    "@superego/quickjs-javascript-sandbox": "workspace:*",
    "@superego/schema": "workspace:*",
    "@superego/themes": "workspace:*",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/luxon": "^3.7.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitest/browser": "^4.1.5",
    "@vitest/browser-playwright": "^4.1.5",
    "playwright": "^1.59.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "zx": "8.8.5-lite"
  }
}
