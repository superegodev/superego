{
  "name": "@superego/demo-app",
  "version": "2026.5.5",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "yarn generate-demo-data-snapshot --if-missing && vite",
    "clear-vite-cache": "rm -rf node_modules/.vite node_modules/.vite-temp",
    "check-types": "yarn generate-demo-data-snapshot --if-missing && tsc --noEmit",
    "clean": "rm -rf dist",
    "generate-demo-data-snapshot": "node scripts/generateDemoDataSnapshot.mjs",
    "build:preview": "yarn clean && yarn generate-demo-data-snapshot && vite build",
    "build:production": "yarn clean && VITE_DEPLOY_ENVIRONMENT=production yarn generate-demo-data-snapshot && VITE_DEPLOY_ENVIRONMENT=production vite build",
    "deploy:preview": "wrangler pages deploy dist/ --project-name demosuperegodev",
    "deploy:production": "wrangler deploy"
  },
  "dependencies": {
    "@superego/app-sandbox": "workspace:*",
    "@superego/backend": "workspace:*",
    "@superego/boutique": "workspace:*",
    "@superego/browser-app": "workspace:*",
    "@superego/demo-data-repositories": "workspace:*",
    "@superego/executing-backend": "workspace:*",
    "@superego/fake-typescript-sandbox": "workspace:*",
    "@superego/monaco-typescript-compiler": "workspace:*",
    "@superego/multi-driver-inference-service": "workspace:*",
    "@superego/schema": "workspace:*",
    "@superego/shared-utils": "workspace:*",
    "@tanstack/react-query": "^5.100.14",
    "urlpattern-polyfill": "^10.1.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.38.0",
    "@cloudflare/workers-types": "4.20260526.1",
    "@superego/tsc-typescript-compiler": "workspace:*",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "wrangler": "^4.94.0"
  }
}
