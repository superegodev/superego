---
import { Image } from "astro:assets";
import { Icon } from "@astrojs/starlight/components";
import getStarCount from "../utils/getStarCount";
import logo from "../assets/logo.svg";

const starsCount = await getStarCount();
const formattedStars =
  typeof starsCount === "number"
    ? new Intl.NumberFormat("en-US").format(starsCount)
    : "—";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Superego</title>
    <meta
      name="description"
      content="An open-source, local-first personal data store and app platform."
    />
  </head>
  <body>
    <div class="bg-icons" aria-hidden="true">
      <span
        class="bg-icon"
        style="--offset-x:-399px;--offset-y:-45px;--rotation:-12deg;--range:35vh"
        >🏃</span
      >
      <span
        class="bg-icon"
        style="--offset-x:-536px;--offset-y:84px;--rotation:-14deg;--range:40vh"
        >🩺</span
      >
      <span
        class="bg-icon"
        style="--offset-x:-843px;--offset-y:56px;--rotation:-13deg;--range:50vh"
        >🌱</span
      >
      <span
        class="bg-icon"
        style="--offset-x:776px;--offset-y:258px;--rotation:1deg;--range:45vh"
        >😊</span
      >
      <span
        class="bg-icon"
        style="--offset-x:535px;--offset-y:-190px;--rotation:6deg;--range:30vh"
        >✅</span
      >
      <span
        class="bg-icon"
        style="--offset-x:809px;--offset-y:-129px;--rotation:5deg;--range:48vh"
        >📝</span
      >
      <span
        class="bg-icon"
        style="--offset-x:-607px;--offset-y:243px;--rotation:9deg;--range:42vh"
        >👤</span
      >
      <span
        class="bg-icon"
        style="--offset-x:481px;--offset-y:189px;--rotation:11deg;--range:33vh"
        >📅</span
      >
      <span
        class="bg-icon"
        style="--offset-x:-563px;--offset-y:-347px;--rotation:13deg;--range:52vh"
        >📚</span
      >
      <span
        class="bg-icon"
        style="--offset-x:680px;--offset-y:414px;--rotation:-10deg;--range:38vh"
        >🍳</span
      >
      <span
        class="bg-icon"
        style="--offset-x:600px;--offset-y:-376px;--rotation:-5deg;--range:46vh"
        >💸</span
      >
      <span
        class="bg-icon"
        style="--offset-x:-865px;--offset-y:308px;--rotation:9deg;--range:55vh"
        >💊</span
      >
      <span
        class="bg-icon"
        style="--offset-x:-720px;--offset-y:391px;--rotation:-14deg;--range:44vh"
        >🎯</span
      >
      <span
        class="bg-icon"
        style="--offset-x:-642px;--offset-y:-140px;--rotation:-3deg;--range:36vh"
        >💡</span
      >
      <span
        class="bg-icon"
        style="--offset-x:-766px;--offset-y:-434px;--rotation:13deg;--range:50vh"
        >✈️</span
      >
      <span
        class="bg-icon"
        style="--offset-x:678px;--offset-y:59px;--rotation:5deg;--range:32vh"
        >🍗</span
      >
      <span
        class="bg-icon"
        style="--offset-x:831px;--offset-y:-421px;--rotation:-10deg;--range:53vh"
        >💤</span
      >
      <span
        class="bg-icon"
        style="--offset-x:814px;--offset-y:159px;--rotation:10deg;--range:47vh"
        >📊</span
      >
      <span
        class="bg-icon"
        style="--offset-x:362px;--offset-y:-15px;--rotation:5deg;--range:28vh"
        >🐾</span
      >
      <span
        class="bg-icon"
        style="--offset-x:-874px;--offset-y:-238px;--rotation:1deg;--range:51vh"
        >🔗</span
      >
    </div>
    <header class="sticky-header">
      <div class="sticky-inner">
        <div class="sticky-brand">
          <Image
            src={logo}
            alt="Superego logo"
            class="sticky-logo"
            height={32}
          />
          <span>Superego</span>
        </div>
        <div class="sticky-actions">
          <a
            href={import.meta.env["PUBLIC_DISCORD_INVITE_URL"]}
            class="icon-link"
            aria-label="Join the Superego Discord"
          >
            <Icon name="discord" class="icon" />
          </a>
          <a
            href="https://github.com/superegodev/superego"
            class="icon-link"
            aria-label="Superego on GitHub"
          >
            <Icon name="github" class="icon" />
          </a>
          <a href="https://demo.superego.dev" class="button button-header">
            Try demo
          </a>
        </div>
      </div>
    </header>
    <main>
      <section class="fold">
        <section class="tagline">
          <p><u>ditch</u> your apps</p>
          <p><u>build</u> your own</p>
          <p><u>own</u> your data</p>
        </section>

        <section class="hero">
          <div class="logo-container">
            <Image src={logo} alt="Superego logo" class="logo" height={140} />
            <Image
              src={logo}
              alt=""
              class="logo-glitch"
              aria-hidden="true"
              height={140}
            />
          </div>
          <h1 class="title">Superego</h1>
          <p class="subtitle">A personal data store and app platform</p>
          <div class="actions">
            <a href="https://demo.superego.dev" class="button">
              Try demo
              <div class="additional-info">(no login)</div>
            </a>
            <a
              href="https://github.com/superegodev/superego/releases/latest"
              class="button button-secondary"
            >
              Download
              <div class="additional-info">(alpha)</div>
            </a>
          </div>
          <div class="highlights">
            <span class="highlight-item">
              <Icon name="github" class="icon highlight-icon" />
              {formattedStars} stars
            </span>
            <div role="separator" aria-orientation="vertical"></div>
            <span class="highlight-item">Local-first</span>
            <div role="separator" aria-orientation="vertical"></div>
            <span class="highlight-item">AGPL-3.0</span>
          </div>
          <span class="scroll-hint">&raquo;</span>
        </section>
      </section>

      <section class="explainer">
        <h2>You Deserve Better Software</h2>
        <p>
          <b>Apps are not serving you.</b> They serve growth targets, while you get
          bloat, banners, enshittification, and monthly subscription bills.
        </p>
        <p>
          <b>You don't have control of your data.</b> It's scattered across those
          apps, trapped.
        </p>
        <h2>So We Built Superego</h2>
        <p>
          A private place to <b>collect all your data</b> and a platform to
          <b>build (or vibe) your <i>home-cooked</i> apps</b>.
        </p>
        <p>
          Need a portfolio tracker? Skip the <i>one-size-fits-all</i>, and make
          one just like
          <b>you</b> want it.
        </p>
        <p>
          A chore scoreboard for your family? Too niche for the app stores, but
          you can <b>build it yourself</b>.
        </p>
        <h2>With an AI That Actually Knows You</h2>
        <p>
          Bring your own LLM. Direct access to your data gives it a
          <b>precise understanding</b> of your world.
        </p>
        <blockquote>
          I need 30k for a car. What stocks should I sell?
        </blockquote>
        <p>
          <a href="https://demo.superego.dev">Try it in the demo</a>. Can
          ChatGPT answer that?
        </p>
        <h2>See It in Action</h2>
        <div>
          <iframe
            src={import.meta.env["PUBLIC_DEMO_VIDEO_URL"]}
            title="Superego Demo Video"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            referrerpolicy="strict-origin-when-cross-origin"
            allowfullscreen></iframe>
        </div>
        <h2>Feature Highlights</h2>
        <ul>
          <li>Open-source, local-first, no-login.</li>
          <li>Everything in <b>one single SQLite file</b>.</li>
          <li>
            CLI to integrate with your personal <a
              href="https://simonwillison.net/2026/Feb/21/claws/"><i>Claw</i></a
            > (for managing data) or coding agent (for writing apps).
          </li>
        </ul>
        <h2>Roadmap</h2>
        <ul class="roadmap">
          <li class="done">
            <span class="sr-only">Done: </span>Document versioning.
          </li>
          <li class="done">
            <span class="sr-only">Done: </span>Full-text search.
          </li>
          <li class="in-progress">
            <span class="sr-only">In progress: </span>CLI.
          </li>
          <li class="todo">
            <span class="sr-only">To do: </span>AI-assisted data import.
          </li>
          <li class="todo"><span class="sr-only">To do: </span>Mobile app.</li>
          <li class="todo">
            <span class="sr-only">To do: </span>Sync via file-syncing service.
          </li>
          <li class="todo">
            <span class="sr-only">To do: </span>Database encryption.
          </li>
          <li class="todo">
            <span class="sr-only">To do: </span>Database hooks.
          </li>
        </ul>
        <h2>Sounds good?</h2>
        <div class="actions">
          <a href="https://demo.superego.dev" class="button">
            Try demo
            <div class="additional-info">(no login)</div>
          </a>
          <a
            href="https://github.com/superegodev/superego/releases/latest"
            class="button button-secondary"
          >
            Download
            <div class="additional-info">(alpha)</div>
          </a>
        </div>
      </section>
    </main>
    <footer class="footer">
      <nav class="footer-links">
        <a href="/connectors/">Docs</a>
        <a href="https://github.com/superegodev/superego">GitHub</a>
        <a href={import.meta.env["PUBLIC_DISCORD_INVITE_URL"]}>Discord</a>
      </nav>
      <p class="footer-license">© 2026 Paolo Scanferla · AGPL-3.0</p>
    </footer>
  </body>
  <script>
    const scrollHint = document.querySelector(".scroll-hint");
    const header = document.querySelector<HTMLElement>(".sticky-header");

    const supportsScrollTimeline = CSS.supports(
      "animation-timeline",
      "scroll()",
    );

    const icons = !supportsScrollTimeline
      ? [...document.querySelectorAll<HTMLElement>(".bg-icon")].map(
          (element) => {
            const style = getComputedStyle(element);
            return {
              element,
              offsetX: parseFloat(style.getPropertyValue("--offset-x")),
              offsetY: parseFloat(style.getPropertyValue("--offset-y")),
              range:
                (parseFloat(style.getPropertyValue("--range")) *
                  window.innerHeight) /
                100,
            };
          },
        )
      : [];

    const onScroll = () => {
      scrollHint?.classList.toggle("is-hidden", window.scrollY > 24);

      if (!supportsScrollTimeline && header) {
        const start = window.innerHeight * 0.7;
        const end = window.innerHeight;
        const progress = Math.min(
          1,
          Math.max(0, (window.scrollY - start) / (end - start)),
        );
        header.style.translate = `0 ${-100 + progress * 100}%`;
        header.style.opacity = String(progress);
        header.style.pointerEvents = progress > 0 ? "auto" : "none";
      }

      for (const icon of icons) {
        const progress = Math.min(1, Math.max(0, window.scrollY / icon.range));
        const translateX = (-icon.offsetX - 20) * progress;
        const translateY = (-icon.offsetY + 20) * progress;
        icon.element.style.translate = `${translateX}px ${translateY}px`;
      }
    };

    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });
  </script>
</html>

<style>
  :root {
    --bg: #fff;
    --fg: #000;
    --tagline: #000;
    --subtitle: #555;
    --btn-primary-bg: #000;
    --btn-primary-fg: #fff;
    --btn-primary-inner-border: #fff;
    --btn-secondary-bg: #fff;
    --btn-secondary-fg: #000;
    --btn-secondary-border: #000;
    --accent: #e63946;
    --border: 3px solid #000;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #0a0a0a;
      --fg: #fff;
      --tagline: #fff;
      --subtitle: #999;
      --btn-primary-bg: #fff;
      --btn-primary-fg: #000;
      --btn-primary-inner-border: #000;
      --btn-secondary-bg: #0a0a0a;
      --btn-secondary-fg: #fff;
      --btn-secondary-border: #fff;
      --border: 3px solid #fff;
    }
  }

  @keyframes pull-to-center {
    from {
      translate: 0 0;
    }
    to {
      translate: calc(-1 * var(--offset-x) - 20px)
        calc(-1 * var(--offset-y) + 20px);
    }
  }

  .bg-icons {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
    mask-image: radial-gradient(
      circle at center,
      black 0%,
      black 70%,
      transparent 95%
    );
  }

  .bg-icon {
    position: absolute;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3.5rem;
    height: 3.5rem;
    font-size: 1.8rem;
    background: var(--bg);
    border: var(--border);
    box-shadow: 3px 3px 0 var(--fg);
    opacity: 0.7;
    top: calc(50vh + var(--offset-y));
    left: calc(50vw + var(--offset-x));
    transform: rotate(var(--rotation));
  }

  @supports (animation-timeline: scroll()) {
    .bg-icon {
      animation: pull-to-center linear forwards;
      animation-timeline: scroll(root);
      animation-range: 0vh var(--range);
    }
  }

  @media (max-width: 900px) {
    .bg-icon {
      width: 2.8rem;
      height: 2.8rem;
      font-size: 1.4rem;
    }
  }

  @media (max-width: 640px) {
    .bg-icons {
      display: none;
    }
  }

  html,
  body {
    margin: 0;
    padding: 0;
    min-height: 100svh;
    background: var(--bg);
    color: var(--fg);
    font-family: monospace;
  }

  main {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 800px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  @keyframes lower-header {
    from {
      translate: 0 -100%;
      opacity: 0;
      pointer-events: none;
    }
    to {
      translate: 0 0;
      opacity: 1;
      pointer-events: auto;
    }
  }

  .sticky-header {
    position: fixed;
    inset-block-start: 0;
    inset-inline: 0;
    z-index: 20;
    background: var(--bg);
    border-block-end: var(--border);
    translate: 0 -100%;
    opacity: 0;
    pointer-events: none;
  }

  @supports (animation-timeline: scroll()) {
    .sticky-header {
      animation: lower-header linear forwards;
      animation-timeline: scroll(root);
      animation-range: 70vh 100vh;
    }
  }

  .sticky-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    box-sizing: border-box;
    padding: 1rem 2rem;
    gap: 1rem;
  }

  .sticky-brand {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    font-weight: 900;
    font-size: 2rem;
  }

  @media (min-width: 1024px) {
    .sticky-header {
      background: transparent;
      border-block-end: none;
    }
  }

  @media (max-width: 640px) {
    .sticky-brand span {
      display: none;
    }
  }

  .sticky-logo {
    width: 40px;
    height: 40px;
  }

  .sticky-actions {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .icon-link {
    color: var(--fg);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .icon-link:hover {
    background: var(--fg);
    color: var(--bg);
  }

  .icon {
    width: 2.2rem;
    height: 2.2rem;
  }

  .fold {
    display: flex;
    flex-direction: column;
    min-height: 100svh;
    width: 100%;
  }

  .tagline {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    font-size: clamp(2rem, 1rem + 4.1vw, 4rem);
    font-style: normal;
    text-align: center;
    color: var(--tagline);
  }

  .tagline p {
    margin-block: 0.5rem;
    line-height: 1.1;
  }

  .tagline u {
    font-weight: 900;
    font-size: 1.2em;
    text-decoration: none;
    background: var(--fg);
    color: var(--bg);
    padding-inline: 0.15em;
    margin-inline-end: -0.15rem;
    display: inline-block;
    transform: rotate(2deg);
  }

  .tagline p:first-child u {
    transform: rotate(-2deg);
  }

  .tagline p:last-child u {
    transform: rotate(-2deg);
    background: var(--accent);
    color: #fff;
  }

  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .logo-container {
    position: relative;
    height: clamp(80px, 120px + 5vw, 140px);
    aspect-ratio: 1 / 1;
    margin-block-end: 1.5rem;
  }

  .logo {
    width: 100%;
    height: 100%;
  }

  .logo-glitch {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0.4;
    animation: glitch 10s infinite;
    animation-delay: -7s;
  }

  @keyframes glitch {
    0%,
    95% {
      display: none;
      transform: translate(0);
      filter: none;
    }
    96% {
      display: initial;
      transform: translate(-6px, 3px);
      filter: drop-shadow(4px 0 #f00) drop-shadow(-4px 0 #0ff);
    }
    97% {
      display: initial;
      transform: translate(6px, -3px);
      filter: drop-shadow(-4px 0 #f00) drop-shadow(4px 0 #0ff);
    }
    97.5% {
      display: initial;
      transform: translate(-3px, 6px);
      filter: drop-shadow(3px 0 #f00) drop-shadow(-3px 0 #0ff);
    }
    98% {
      display: initial;
      transform: translate(3px, -6px);
      filter: drop-shadow(-3px 0 #f00) drop-shadow(3px 0 #0ff);
    }
    98.5% {
      display: initial;
      transform: translate(-6px, -3px);
      filter: drop-shadow(4px 0 #f00) drop-shadow(-4px 0 #0ff);
    }
    99% {
      display: initial;
      transform: translate(6px, 3px);
      filter: drop-shadow(-4px 0 #f00) drop-shadow(4px 0 #0ff);
    }
    99%,
    100% {
      display: none;
      transform: translate(0);
      filter: none;
    }
  }

  .title {
    font-size: 3rem;
    font-weight: 900;
    margin-block-start: 2rem;
    margin-block-end: 0rem;
    text-align: center;
  }

  .subtitle {
    font-size: 1.75rem;
    margin-block-start: 1rem;
    margin-block-end: 4.5rem;
    text-align: center;
    color: var(--subtitle);
  }

  .actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-block-end: 2rem;
  }

  .actions .button {
    width: 240px;
    text-align: center;
    box-sizing: border-box;
  }

  @media (max-width: 640px) {
    .logo-container {
      height: 80px;
      margin-block-end: 1rem;
    }

    .title {
      font-size: 2rem;
    }

    .subtitle {
      font-size: 1.25rem;
      margin-block-start: 1rem;
      margin-block-end: 2rem;
    }

    .actions .button {
      width: 140px;
      padding: 1rem 1.25rem;
      font-size: 1.2rem;
    }
  }

  .button {
    display: inline-block;
    padding: 1rem 1.75rem;
    text-decoration: none;
    background: var(--btn-primary-bg);
    color: var(--btn-primary-fg);
    font-weight: 800;
    font-size: 1.5rem;
    text-transform: uppercase;
    border: var(--border);
    outline: 2px solid var(--btn-primary-inner-border);
    outline-offset: -5px;
    box-shadow: 4px 4px 0 var(--fg);
    transform: translate(-2px, -2px);
    transition:
      transform 0.1s linear,
      box-shadow 0.1s linear;
  }

  .button:hover {
    transform: translate(0, 0);
    box-shadow: 2px 2px 0 var(--fg);
  }

  .button-secondary {
    background: var(--btn-secondary-bg);
    color: var(--btn-secondary-fg);
    border: var(--border);
  }

  .button-header {
    font-size: 1rem;
    padding: 0.8rem 1.4rem;
    box-shadow: 2px 2px 0 var(--fg);
    transform: translate(-1px, -1px);
  }

  .button-header:hover {
    box-shadow: 1px 1px 0 var(--fg);
    transform: translate(0, 0);
  }

  .additional-info {
    font-size: 0.7em;
    font-weight: 400;
    text-transform: none;
    margin-block-start: 0.25rem;
  }

  .highlights {
    display: flex;
    align-items: center;
    gap: 1.3rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-block-end: 3rem;
    width: 100%;
    color: var(--subtitle);
    font-size: 1rem;
  }

  .highlight-item {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    justify-content: center;
    text-align: center;
  }

  .highlight-item:first-child {
    width: 90px;
    justify-content: flex-end;
  }
  .highlight-item:last-child {
    width: 90px;
    justify-content: flex-start;
  }

  .highlights div[role="separator"] {
    width: 2px;
    height: 1.2em;
    background-color: var(--fg);
  }

  .highlight-icon {
    width: 1rem;
    height: 1rem;
  }

  .scroll-hint {
    display: block;
    font-size: 2.5rem;
    color: var(--subtitle);
    transform: rotate(90deg);
    transition: opacity 0.1s linear;
    animation: bounce 8s infinite;
    animation-delay: 8s;
  }

  @keyframes bounce {
    0% {
      translate: 0 -100vh;
      scale: 1.5;
      animation-timing-function: cubic-bezier(0.33, 0, 0.66, 0);
    }
    3% {
      translate: 0 0;
      scale: 1.5;
      animation-timing-function: cubic-bezier(0.33, 1, 0.66, 1);
